{
  "manifest_version": 3,
  "name": "POE2 Purchase History",
  "short_name": "POE2 History",
  "version": "1.1.6",
  "description": "Track your Path of Exile 2 purchase history directly from the trade site.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.pathofexile.com/trade2*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.pathofexile.com/trade2*"
      ],
      "js": ["content/content.js"],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "POE2 Purchase History",
    "default_icon": {
      "16": "icons/chest_16.png",
      "48": "icons/chest_48.png",
      "128": "icons/chest_128.png"
    }
  },
  "icons": {
    "16": "icons/chest_16.png",
    "48": "icons/chest_48.png",
    "128": "icons/chest_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/content.css",
        "icons/*.png",
        "icons/classes/*.webp",
        "popup/flags/*.png"
      ],
      "matches": [
        "*://*.pathofexile.com/*"
      ]
    }
  ]
}
